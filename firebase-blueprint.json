{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "User ID" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "customer"] },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "Peptide product details",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "categories": { "type": "array", "items": { "type": "string" } },
        "specifications": { "type": "array", "items": { "type": "string" } },
        "inventory": { "type": "number" },
        "images": { "type": "array", "items": { "type": "string" } },
        "rating": { "type": "number" },
        "reviewCount": { "type": "number" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["title", "description", "price", "inventory", "createdAt"]
    },
    "Category": {
      "title": "Category",
      "description": "Product category",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "slug": { "type": "string" }
      },
      "required": ["name", "slug"]
    },
    "Order": {
      "title": "Order",
      "description": "Customer order",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "items": { "type": "array" },
        "totalAmount": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "paid", "shipped", "delivered"] },
        "shippingAddress": { "type": "object" },
        "cryptoTxHash": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["userId", "items", "totalAmount", "status", "shippingAddress", "createdAt"]
    },
    "Review": {
      "title": "Review",
      "description": "Product review",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "userId": { "type": "string" },
        "authorName": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["productId", "userId", "authorName", "rating", "comment", "createdAt"]
    },
    "Wishlist": {
      "title": "Wishlist",
      "description": "User wishlist",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "productIds": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["userId", "productIds"]
    },
    "BlogPost": {
      "title": "BlogPost",
      "description": "Blog post for SEO and marketing",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "authorId": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["title", "content", "authorId", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/products/{productId}": {
      "schema": { "$ref": "#/entities/Product" },
      "description": "Product catalog"
    },
    "/categories/{categoryId}": {
      "schema": { "$ref": "#/entities/Category" },
      "description": "Product categories"
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "Customer orders"
    },
    "/reviews/{reviewId}": {
      "schema": { "$ref": "#/entities/Review" },
      "description": "Product reviews"
    },
    "/wishlists/{wishlistId}": {
      "schema": { "$ref": "#/entities/Wishlist" },
      "description": "User wishlists"
    },
    "/blogPosts/{postId}": {
      "schema": { "$ref": "#/entities/BlogPost" },
      "description": "Blog posts"
    }
  }
}
