rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: users
    // Document ID: {userId}
    // Fields:
    //   - uid: string (required)
    //   - email: string (required)
    //   - displayName: string (optional)
    //   - photoURL: string (optional)
    //   - role: string (required, 'admin' or 'customer')
    //   - createdAt: timestamp (required)
    //
    // Collection: products
    // Document ID: {productId}
    // Fields:
    //   - title: string (required)
    //   - description: string (required)
    //   - price: number (required)
    //   - categories: list (optional)
    //   - specifications: list (optional)
    //   - inventory: number (required)
    //   - images: list (optional)
    //   - rating: number (optional)
    //   - reviewCount: number (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: categories
    // Document ID: {categoryId}
    // Fields:
    //   - name: string (required)
    //   - description: string (optional)
    //   - slug: string (required)
    //
    // Collection: orders
    // Document ID: {orderId}
    // Fields:
    //   - userId: string (required)
    //   - items: list (required)
    //   - totalAmount: number (required)
    //   - status: string (required, 'pending', 'paid', 'shipped', 'delivered')
    //   - shippingAddress: map (required)
    //   - cryptoTxHash: string (optional)
    //   - createdAt: timestamp (required)
    //
    // Collection: reviews
    // Document ID: {reviewId}
    // Fields:
    //   - productId: string (required)
    //   - userId: string (required)
    //   - authorName: string (required)
    //   - rating: number (required)
    //   - comment: string (required)
    //   - createdAt: timestamp (required)
    //
    // Collection: wishlists
    // Document ID: {userId} (using userId as document ID for 1:1 mapping)
    // Fields:
    //   - userId: string (required)
    //   - productIds: list (required)
    //
    // Collection: blogPosts
    // Document ID: {postId}
    // Fields:
    //   - title: string (required)
    //   - content: string (required)
    //   - authorId: string (required)
    //   - tags: list (optional)
    //   - imageUrl: string (optional)
    //   - createdAt: timestamp (required)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.userId;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
          (request.auth.token.email == "ndikumelvis@gmail.com" && request.auth.token.email_verified == true));
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function uidUnchanged() {
      return !('uid' in request.resource.data) || request.resource.data.uid == request.auth.uid;
    }

    function uidNotModified() {
      return !('uid' in request.resource.data) || request.resource.data.uid == resource.data.uid;
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================

    function isValidUser(data) {
      return hasRequiredFields(['uid', 'email', 'role', 'createdAt']) &&
             data.uid is string &&
             data.email is string &&
             data.role in ['admin', 'customer'] &&
             data.createdAt is timestamp;
    }

    function isValidProduct(data) {
      return hasRequiredFields(['title', 'description', 'price', 'inventory', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.description is string && data.description.size() < 10000 &&
             data.price is number && data.price >= 0 &&
             data.inventory is number && data.inventory >= 0 &&
             data.createdAt is timestamp;
    }

    function isValidCategory(data) {
      return hasRequiredFields(['name', 'slug']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.slug is string && data.slug.size() > 0 && data.slug.size() < 100;
    }

    function isValidOrder(data) {
      return hasRequiredFields(['userId', 'items', 'totalAmount', 'status', 'shippingAddress', 'createdAt']) &&
             data.userId is string &&
             data.items is list && data.items.size() > 0 && data.items.size() < 100 &&
             data.totalAmount is number && data.totalAmount >= 0 &&
             data.status in ['pending', 'paid', 'shipped', 'delivered'] &&
             data.shippingAddress is map &&
             data.createdAt is timestamp;
    }

    function isValidReview(data) {
      return hasRequiredFields(['productId', 'userId', 'authorName', 'rating', 'comment', 'createdAt']) &&
             data.productId is string &&
             data.userId is string &&
             data.authorName is string && data.authorName.size() > 0 && data.authorName.size() < 100 &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.comment is string && data.comment.size() > 0 && data.comment.size() < 2000 &&
             data.createdAt is timestamp;
    }

    function isValidWishlist(data) {
      return hasRequiredFields(['userId', 'productIds']) &&
             data.userId is string &&
             data.productIds is list && data.productIds.size() <= 500;
    }

    function isValidBlogPost(data) {
      return hasRequiredFields(['title', 'content', 'authorId', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.content is string && data.content.size() > 0 && data.content.size() < 50000 &&
             data.authorId is string &&
             data.createdAt is timestamp;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(userId) && isValidUser(request.resource.data) && 
                    ((request.resource.data.role == 'customer') || isAdmin());
      allow update: if isAuthenticated() && isValidUser(request.resource.data) && 
                    ((isOwner(userId) && request.resource.data.role == resource.data.role && uidNotModified()) || isAdmin());
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && (request.method == 'delete' || isValidProduct(request.resource.data));
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && (request.method == 'delete' || isValidCategory(request.resource.data));
    }

    match /orders/{orderId} {
      allow read: if isDocOwner() || isAdmin();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidOrder(request.resource.data);
      allow update: if isAdmin() && isValidOrder(request.resource.data);
      allow delete: if isAdmin();
    }

    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid && isValidReview(request.resource.data);
      allow update: if (isDocOwner() || isAdmin()) && isValidReview(request.resource.data) && request.resource.data.userId == resource.data.userId && request.resource.data.productId == resource.data.productId;
      allow delete: if isDocOwner() || isAdmin();
    }

    match /wishlists/{wishlistId} {
      allow read: if isOwner(wishlistId) || isAdmin();
      allow create: if isAuthenticated() && isOwner(wishlistId) && request.resource.data.userId == request.auth.uid && isValidWishlist(request.resource.data);
      allow update: if isAuthenticated() && isOwner(wishlistId) && isValidWishlist(request.resource.data) && request.resource.data.userId == resource.data.userId;
      allow delete: if isOwner(wishlistId) || isAdmin();
    }

    match /blogPosts/{postId} {
      allow read: if true;
      allow create, update, delete: if isAdmin() && (request.method == 'delete' || isValidBlogPost(request.resource.data));
    }
  }
}
