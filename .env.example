VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key"
VITE_SITE_URL="https://www.researchpeptide.uk"

# Google Analytics 4 — Admin → Data Streams → Web → Measurement ID (format G-XXXXXXXXXX)
# Account: Research Peptides UK (395411140) | Property: 538450148
VITE_GA4_MEASUREMENT_ID="G-XXTCQPY79Y"

# Optional: Google Tag Manager container (use GA4 OR GTM, not both unless GTM loads GA4)
# VITE_GTM_ID="GTM-XXXXXXX"

# Optional: HTML-tag Search Console verification (only if not verified via DNS)
# VITE_GSC_VERIFICATION="your-verification-token"

# Set true in Vercel production so build fetches live products/posts for sitemap + prerender HTML.
SEO_FETCH_REMOTE="true"
# Optional but recommended for complete build-time SEO exports (products + blog prerender). Server-only; do not expose with VITE_.
# SUPABASE_URL="https://your-project.supabase.co"
# SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
# VITE_DEV_API_PROXY="http://127.0.0.1:3000"

# Comma-separated emails that should be created as admin on first signup (DB row must still use role=admin for RLS — see server/migrations/003_admin_rls_orders_products.sql).
# VITE_ADMIN_EMAILS="you@example.com,other@example.com"

# Smartsupp live chat (frontend)
# Get key from Smartsupp dashboard → Chat box installation.
# VITE_SMARTSUPP_KEY="YOUR_SMARTSUPP_KEY"
# Optional brand color for the widget launcher/header.
# VITE_SMARTSUPP_COLOR="#2563eb"
# Optional: lift widget above mobile bottom nav (in px).
# VITE_SMARTSUPP_MOBILE_OFFSET_Y="88"

# Psilio (server-side invoice creation; keep secrets out of VITE_ vars)
# PSILIO_SECRET_KEY="your_psilio_secret"
# PSILIO_CREATE_INVOICE_URL="https://api.plisio.net/api/v1/invoices/new"
# PSILIO_STATUS_URL="https://www.researchpeptide.uk/api/payments/psilio/status"
# PSILIO_SUCCESS_URL="https://www.researchpeptide.uk/checkout?payment=success"
# PSILIO_FAILED_URL="https://www.researchpeptide.uk/checkout?payment=failed"

# --- Vercel (Dashboard → Settings → Environment Variables; used by api/* serverless routes) ---
# RESEND_API_KEY="re_..."
# RESEND_FROM="Research Peptides Official <info@researchpeptide.uk>"
# RESEND_BASE_URL="https://api.resend.com"
# EMAIL_FROM="same-as-RESEND_FROM if you prefer"
# EMAIL_ADMIN_TO="info@researchpeptide.uk"   # single admin inbox (launch default)
# EMAIL_BRAND_NAME="Research Peptides"
# EMAIL_SUPPORT_ADDRESS="info@researchpeptide.uk"
# EMAIL_DRY_RUN="false"
# SUPABASE_URL="https://your-project.supabase.co"
# SUPABASE_SERVICE_ROLE_KEY="service_role_secret"

# Launch note:
# - Frontend uses VITE_SUPABASE_*.
# - Serverless email routes (/api/email/*) require SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY + RESEND_*.
